{
  "说明": "这是示例模板，不含任何真实密钥。将此文件复制为 volc-ark-apis.json 后填入你自己的密钥，再用 encrypt_tool.js 加密并更新 js/ark-api-config.js 中的密文锁。",
  "dataApiKey": "在此填写 火山方舟 / 豆包大模型推理 API Key",
  "translationApiKey": "",
  "qiaozhuangApiKey": "在此填写 侨壮壮智能体 API Key（与 dataApiKey 可相同）",
  "baiduMapAk": "在此填写 百度地图开放平台浏览器端 AK",

  "ARK_DATA_CHAT_DEFAULTS": {
    "endpoint": "https://ark.cn-beijing.volces.com/api/v3/chat/completions",
    "model": "ep-你的模型接入点ID"
  },

  "ARK_QIAOZHUANG_DEFAULTS": {
    "endpoint": "https://ark.cn-beijing.volces.com/api/v3/bots/chat/completions",
    "model": "bot-你的智能体BotID"
  },

  "ARK_TRANSLATION_RESPONSES_DEFAULTS": {
    "endpoint": "https://ark.cn-beijing.volces.com/api/v3/responses",
    "model": "ep-你的翻译模型接入点ID"
  },

  "TRANSLATION_ARK": {
    "enabled": true
  },

  "DATA_ACQUISITION_ARK": {
    "enabled": true,
    "temperature": 0.35,
    "max_tokens": 12288,
    "cacheTtlMs": 600000
  },

  "ASSISTANT_ARK": {
    "use_stream": true
  }
}
